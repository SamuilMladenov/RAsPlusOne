# Copy to `.env` in this folder (backend/) and adjust secrets.
# Used by the API for JWT and demo logins.

JWT_SECRET_KEY=replace-with-a-long-random-string-for-production
JWT_EXPIRE_MINUTES=1440

# Admin — full dispatch UI (map, patients, ambulances, emergencies, all hospitals)
AUTH_ADMIN_EMAIL=admin@rasplusone.local
AUTH_ADMIN_PASSWORD=AdminDemo2024!

# Triager — mobile /triage flow only (capture triage card photos). Stored under backend/data/triage_photos/ unless TRIAGE_UPLOAD_DIR is set.
AUTH_TRIAGER_EMAIL=triager@rasplusone.local
AUTH_TRIAGER_PASSWORD=TriagerDemo2024!
# TRIAGE_UPLOAD_DIR=/absolute/path/to/triage_photos

# Hospital staff — only their dashboard (match HOSPITAL_ID to a hospital in seed data)
AUTH_HOSPITAL_1_EMAIL=stanna@h-seed01.local
AUTH_HOSPITAL_1_PASSWORD=HospitalSeed01!
AUTH_HOSPITAL_1_HOSPITAL_ID=H-SEED01

AUTH_HOSPITAL_2_EMAIL=central@h-seed02.local
AUTH_HOSPITAL_2_PASSWORD=HospitalSeed02!
AUTH_HOSPITAL_2_HOSPITAL_ID=H-SEED02

AUTH_HOSPITAL_3_EMAIL=academic@h-seed03.local
AUTH_HOSPITAL_3_PASSWORD=HospitalSeed03!
AUTH_HOSPITAL_3_HOSPITAL_ID=H-SEED03
